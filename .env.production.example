APP_NAME="Portfolio CMS"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.nl
APP_TIMEZONE=Europe/Amsterdam
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/cms/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ── Mail ─────────────────────────────────────────────────────────────────────
# Transactional email for contact form notifications.
# Recommended providers: Postmark, Resend, Mailgun, or any SMTP host.
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=                    # your SMTP username / API token
MAIL_PASSWORD=                    # your SMTP password / API token
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@yourdomain.nl"
MAIL_FROM_NAME="Portfolio CMS"

# ── Storage ───────────────────────────────────────────────────────────────────
# Project images are stored locally; no S3 needed for a single-server setup.
# If you ever move to object storage, set FILESYSTEM_DISK=s3 and fill these in.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=
